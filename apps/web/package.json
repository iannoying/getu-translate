{
  "name": "@getu/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "build:prod": "NEXT_PUBLIC_API_BASE_URL=https://api.getutranslate.com next build",
    "_comment_pages_deploy": "named pages:deploy (not 'deploy') so pnpm's builtin `pnpm deploy` doesn't shadow it",
    "pages:deploy": "pnpm run build:prod && wrangler pages deploy out --project-name=getu-web --branch=main",
    "start": "next start",
    "lint": "echo 'web lint-todo (migrate off deprecated next lint to direct eslint)'",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@better-auth/passkey": "1.6.3",
    "@getu/contract": "workspace:*",
    "@orpc/client": "^1.13.14",
    "better-auth": "^1.6.3",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.84.0"
  }
}
