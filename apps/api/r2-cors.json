{
  "rules": [
    {
      "id": "getu-web-document-upload",
      "allowed": {
        "origins": [
          "https://getutranslate.com",
          "https://www.getutranslate.com",
          "http://localhost:3000",
          "http://127.0.0.1:3000"
        ],
        "methods": [
          "PUT",
          "GET",
          "HEAD"
        ],
        "headers": [
          "content-type",
          "content-length"
        ]
      },
      "exposeHeaders": [
        "etag"
      ],
      "maxAgeSeconds": 3000
    }
  ]
}
